var tipuesearch = {"pages":[{"title":" Shallow Water ","text":"Shallow Water This small project is to play around with the shallow water equations and different numerical approaches to solve them. It is also my way to test the capability of AI coding support with less commonly used languages like Fortran. Developer Info Daniel Rouzafzoun-Leukauf","tags":"home","url":"index.html"},{"title":"SimParams – Shallow Water ","text":"type, public :: SimParams Simulation parameters type bundling all run-time settings. Components Type Visibility Attributes Name Initial integer, public :: nx = 100 Grid dimensions integer, public :: ny = 100 real(kind=dp), public :: x_min = 0.0_dp Domain extents (metres) real(kind=dp), public :: x_max = 1000.0_dp real(kind=dp), public :: y_min = 0.0_dp real(kind=dp), public :: y_max = 1000.0_dp real(kind=dp), public :: t_start = 0.0_dp Temporal settings real(kind=dp), public :: t_end = 100.0_dp real(kind=dp), public :: dt = 0.1_dp real(kind=dp), public :: cfl = 0.5_dp integer, public :: output_freq = 10 Output settings character(len=256), public :: output_dir = 'output'","tags":"","url":"type\\simparams.html"},{"title":"IntegratorPtr – Shallow Water ","text":"type, public :: IntegratorPtr Components Type Visibility Attributes Name Initial procedure( advance_step ), public, pointer, nopass :: ptr => null()","tags":"","url":"type\\integratorptr.html"},{"title":"SWEState – Shallow Water ","text":"type, public :: SWEState SWE state on a 2-D grid. Components Type Visibility Attributes Name Initial real(kind=dp), public, allocatable :: h (:,:) real(kind=dp), public, allocatable :: hu (:,:) real(kind=dp), public, allocatable :: hv (:,:)","tags":"","url":"type\\swestate.html"},{"title":"GridBase – Shallow Water ","text":"type, public :: GridBase Minimal grid descriptor shared by all grid types. Components Type Visibility Attributes Name Initial integer, public :: nx integer, public :: ny real(kind=dp), public :: dx real(kind=dp), public :: dy","tags":"","url":"type\\gridbase.html"},{"title":"CartesianGrid – Shallow Water ","text":"type, public, extends( GridBase ) :: CartesianGrid Cartesian grid type. Components Type Visibility Attributes Name Initial integer, public :: nx integer, public :: ny real(kind=dp), public :: dx real(kind=dp), public :: dy real(kind=dp), public, allocatable :: x (:) 1-D arrays of cell-centre coordinates real(kind=dp), public, allocatable :: y (:)","tags":"","url":"type\\cartesiangrid.html"},{"title":"advance_step – Shallow Water","text":"interface Abstract interface satisfied by every time-integration scheme. public  subroutine advance_step(state, b, dx, dy, dt) Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt","tags":"","url":"interface\\advance_step.html"},{"title":"default_params – Shallow Water","text":"public  function default_params() result(p) Return a SimParams struct filled with default values. Arguments None Return Value type( SimParams )","tags":"","url":"proc\\default_params.html"},{"title":"write_csv – Shallow Water","text":"public  subroutine write_csv(state, x, y, step, output_dir, prefix) Write the current state to a CSV file. File path: / _ .csv\nColumns: x_index, y_index, h, u, v, hu, hv Arguments Type Intent Optional Attributes Name type( SWEState ), intent(in) :: state real(kind=dp), intent(in) :: x (:) real(kind=dp), intent(in) :: y (:) integer, intent(in) :: step character(len=*), intent(in) :: output_dir character(len=*), intent(in) :: prefix","tags":"","url":"proc\\write_csv.html"},{"title":"max_wave_speed – Shallow Water","text":"public  function max_wave_speed(state) result(smax) Compute the maximum wave speed across the domain.\nUsed for CFL-limited time-step selection. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(in) :: state Return Value real(kind=dp)","tags":"","url":"proc\\max_wave_speed.html"},{"title":"rusanov_flux_x – Shallow Water","text":"public  subroutine rusanov_flux_x(fh, fhu, fhv, state, i, j) Rusanov (local Lax-Friedrichs) flux in the x-direction at the\ninterface between cell (i,j) and (i+1,j). Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: fh real(kind=dp), intent(out) :: fhu real(kind=dp), intent(out) :: fhv type( SWEState ), intent(in) :: state integer, intent(in) :: i integer, intent(in) :: j","tags":"","url":"proc\\rusanov_flux_x.html"},{"title":"rusanov_flux_y – Shallow Water","text":"public  subroutine rusanov_flux_y(fh, fhu, fhv, state, i, j) Rusanov flux in the y-direction at the interface (i,j)-(i,j+1). Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: fh real(kind=dp), intent(out) :: fhu real(kind=dp), intent(out) :: fhv type( SWEState ), intent(in) :: state integer, intent(in) :: i integer, intent(in) :: j","tags":"","url":"proc\\rusanov_flux_y.html"},{"title":"allocate_state – Shallow Water","text":"public  subroutine allocate_state(state, nx, ny) Allocate state arrays for an nx × ny grid. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(out) :: state integer, intent(in) :: nx integer, intent(in) :: ny","tags":"","url":"proc\\allocate_state.html"},{"title":"deallocate_state – Shallow Water","text":"public  subroutine deallocate_state(state) Deallocate state arrays. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state","tags":"","url":"proc\\deallocate_state.html"},{"title":"compute_rhs – Shallow Water","text":"public  subroutine compute_rhs(rhs, state, b, dx, dy) Compute the RHS of the SWE using simple central differences.\nThis is a placeholder; production code should use a proper\nRiemann-solver-based flux (see flux_mod.f90). Arguments Type Intent Optional Attributes Name type( SWEState ), intent(out) :: rhs type( SWEState ), intent(in) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy","tags":"","url":"proc\\compute_rhs.html"},{"title":"rk4_step – Shallow Water","text":"public  subroutine rk4_step(state, b, dx, dy, dt) Advance the SWE state by one time step using the classical RK4 method. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt","tags":"","url":"proc\\rk4_step.html"},{"title":"euler_step – Shallow Water","text":"public  subroutine euler_step(state, b, dx, dy, dt) Advance the SWE state by one time step using the forward Euler method. U&#94;{n+1} = U&#94;n + dt * RHS(U&#94;n) Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt","tags":"","url":"proc\\euler_step.html"},{"title":"lax_wendroff_step – Shallow Water","text":"public  subroutine lax_wendroff_step(state, b, dx, dy, dt) Advance the SWE state by one time step using the Lax-Wendroff scheme.\nCurrently implemented for 1-D (y-averaged) flow as a placeholder;\nthe full 2-D extension is left for a future implementation. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt","tags":"","url":"proc\\lax_wendroff_step.html"},{"title":"build_cartesian_grid – Shallow Water","text":"public  subroutine build_cartesian_grid(grid, params) Allocate and populate a CartesianGrid from the simulation parameters. Arguments Type Intent Optional Attributes Name type( CartesianGrid ), intent(out) :: grid type( SimParams ), intent(in) :: params","tags":"","url":"proc\\build_cartesian_grid.html"},{"title":"destroy_cartesian_grid – Shallow Water","text":"public  subroutine destroy_cartesian_grid(grid) Deallocate arrays inside a CartesianGrid. Arguments Type Intent Optional Attributes Name type( CartesianGrid ), intent(inout) :: grid","tags":"","url":"proc\\destroy_cartesian_grid.html"},{"title":"read_namelist – Shallow Water","text":"public  subroutine read_namelist(params, filename) Read simulation parameters from a NAMELIST file.\nFalls back to default_params() values for any unset keys. Arguments Type Intent Optional Attributes Name type( SimParams ), intent(out) :: params character(len=*), intent(in) :: filename Namelists Namelist sim_params Variables Name Type Default Description nx integer None ny integer None x_min real(kind=dp) None x_max real(kind=dp) None y_min real(kind=dp) None y_max real(kind=dp) None t_start real(kind=dp) None t_end real(kind=dp) None dt real(kind=dp) None cfl real(kind=dp) None output_freq integer None output_dir character(len=256) None","tags":"","url":"proc\\read_namelist.html"},{"title":"init_terrain_flat – Shallow Water","text":"public  subroutine init_terrain_flat(b, grid) Flat bottom: b = 0 everywhere. Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: b (:,:) type( CartesianGrid ), intent(in) :: grid","tags":"","url":"proc\\init_terrain_flat.html"},{"title":"init_terrain_gaussian_hill – Shallow Water","text":"public  subroutine init_terrain_gaussian_hill(b, grid, amplitude, sigma) Gaussian hill centred in the domain.\nb(x,y) = amplitude * exp( -((x-x0)&#94;2 + (y-y0)&#94;2) / (2*sigma&#94;2) ) Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: b (:,:) type( CartesianGrid ), intent(in) :: grid real(kind=dp), intent(in) :: amplitude real(kind=dp), intent(in) :: sigma","tags":"","url":"proc\\init_terrain_gaussian_hill.html"},{"title":"init_terrain_step – Shallow Water","text":"public  subroutine init_terrain_step(b, grid, x_step, height) Step bathymetry: b = 0 for x < x_step, b = height for x >= x_step. Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: b (:,:) type( CartesianGrid ), intent(in) :: grid real(kind=dp), intent(in) :: x_step real(kind=dp), intent(in) :: height","tags":"","url":"proc\\init_terrain_step.html"},{"title":"parameters_mod – Shallow Water","text":"Runtime simulation parameters (read from config or set as defaults). Uses constants_mod Derived Types type, public :: SimParams Simulation parameters type bundling all run-time settings. Components Type Visibility Attributes Name Initial integer, public :: nx = 100 Grid dimensions integer, public :: ny = 100 real(kind=dp), public :: x_min = 0.0_dp Domain extents (metres) real(kind=dp), public :: x_max = 1000.0_dp real(kind=dp), public :: y_min = 0.0_dp real(kind=dp), public :: y_max = 1000.0_dp real(kind=dp), public :: t_start = 0.0_dp Temporal settings real(kind=dp), public :: t_end = 100.0_dp real(kind=dp), public :: dt = 0.1_dp real(kind=dp), public :: cfl = 0.5_dp integer, public :: output_freq = 10 Output settings character(len=256), public :: output_dir = 'output' Functions public  function default_params () result(p) Return a SimParams struct filled with default values. Arguments None Return Value type( SimParams )","tags":"","url":"module\\parameters_mod.html"},{"title":"output_mod – Shallow Water","text":"Routines for writing simulation results to disk. Supported formats:\n  - Plain text CSV (one file per time step) – easy to read from Python/React\n  - Simple binary (raw doubles) for performance – TODO Uses shallow_water_mod constants_mod Subroutines public  subroutine write_csv (state, x, y, step, output_dir, prefix) Write the current state to a CSV file. Read more… Arguments Type Intent Optional Attributes Name type( SWEState ), intent(in) :: state real(kind=dp), intent(in) :: x (:) real(kind=dp), intent(in) :: y (:) integer, intent(in) :: step character(len=*), intent(in) :: output_dir character(len=*), intent(in) :: prefix","tags":"","url":"module\\output_mod.html"},{"title":"flux_mod – Shallow Water","text":"Numerical flux computations for the SWE. Provides Riemann-solver-based flux routines to be used by the\nhigher-level time-integration schemes.  Currently implements:\n  - Local Lax-Friedrichs (Rusanov) flux Uses shallow_water_mod constants_mod Functions public  function max_wave_speed (state) result(smax) Compute the maximum wave speed across the domain.\nUsed for CFL-limited time-step selection. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(in) :: state Return Value real(kind=dp) Subroutines public  subroutine rusanov_flux_x (fh, fhu, fhv, state, i, j) Rusanov (local Lax-Friedrichs) flux in the x-direction at the\ninterface between cell (i,j) and (i+1,j). Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: fh real(kind=dp), intent(out) :: fhu real(kind=dp), intent(out) :: fhv type( SWEState ), intent(in) :: state integer, intent(in) :: i integer, intent(in) :: j public  subroutine rusanov_flux_y (fh, fhu, fhv, state, i, j) Rusanov flux in the y-direction at the interface (i,j)-(i,j+1). Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: fh real(kind=dp), intent(out) :: fhu real(kind=dp), intent(out) :: fhv type( SWEState ), intent(in) :: state integer, intent(in) :: i integer, intent(in) :: j","tags":"","url":"module\\flux_mod.html"},{"title":"time_integration_mod – Shallow Water","text":"Abstract interface for time-integration schemes. All concrete integrators (Euler, Runge-Kutta, Lax-Wendroff, …) must\nexpose a subroutine with the signature defined by the abstract interface advance_step below.\nProcedure pointer type matching the abstract interface. Uses shallow_water_mod constants_mod Abstract Interfaces abstract interface Abstract interface satisfied by every time-integration scheme. public  subroutine advance_step(state, b, dx, dy, dt) Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt Derived Types type, public :: IntegratorPtr Components Type Visibility Attributes Name Initial procedure( advance_step ), public, pointer, nopass :: ptr => null()","tags":"","url":"module\\time_integration_mod.html"},{"title":"shallow_water_mod – Shallow Water","text":"Core module defining the SWE state vector and the right-hand-side (RHS)\nof the 2-D shallow water equations. The 2-D SWE in conservation form are: ∂h/∂t   + ∂(hu)/∂x + ∂(hv)/∂y  = 0\n  ∂(hu)/∂t + ∂(hu²+g h²/2)/∂x + ∂(huv)/∂y = -g h ∂b/∂x\n  ∂(hv)/∂t + ∂(huv)/∂x + ∂(hv²+g h²/2)/∂y = -g h ∂b/∂y where h = water depth, u = x-velocity, v = y-velocity, b = bed elevation,\ng = gravitational acceleration. Uses constants_mod Derived Types type, public :: SWEState SWE state on a 2-D grid. Components Type Visibility Attributes Name Initial real(kind=dp), public, allocatable :: h (:,:) real(kind=dp), public, allocatable :: hu (:,:) real(kind=dp), public, allocatable :: hv (:,:) Subroutines public  subroutine allocate_state (state, nx, ny) Allocate state arrays for an nx × ny grid. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(out) :: state integer, intent(in) :: nx integer, intent(in) :: ny public  subroutine deallocate_state (state) Deallocate state arrays. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state public  subroutine compute_rhs (rhs, state, b, dx, dy) Compute the RHS of the SWE using simple central differences.\nThis is a placeholder; production code should use a proper\nRiemann-solver-based flux (see flux_mod.f90). Arguments Type Intent Optional Attributes Name type( SWEState ), intent(out) :: rhs type( SWEState ), intent(in) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy","tags":"","url":"module\\shallow_water_mod.html"},{"title":"runge_kutta_mod – Shallow Water","text":"Classical 4th-order Runge-Kutta (RK4) time integration for the SWE. Uses shallow_water_mod constants_mod Subroutines public  subroutine rk4_step (state, b, dx, dy, dt) Advance the SWE state by one time step using the classical RK4 method. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt","tags":"","url":"module\\runge_kutta_mod.html"},{"title":"euler_mod – Shallow Water","text":"Forward Euler (first-order explicit) time integration for the SWE. Uses shallow_water_mod constants_mod Subroutines public  subroutine euler_step (state, b, dx, dy, dt) Advance the SWE state by one time step using the forward Euler method. Read more… Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt","tags":"","url":"module\\euler_mod.html"},{"title":"constants_mod – Shallow Water","text":"Physical and mathematical constants used throughout the solver. Variables Type Visibility Attributes Name Initial integer, public, parameter :: dp = kind(1.0d0) Double-precision kind parameter real(kind=dp), public, parameter :: PI = 3.14159265358979323846_dp Pi real(kind=dp), public, parameter :: GRAVITY = 9.81_dp Gravitational acceleration (m/s&#94;2) real(kind=dp), public, parameter :: EPS = 1.0e-10_dp A small tolerance for floating-point comparisons","tags":"","url":"module\\constants_mod.html"},{"title":"lax_wendroff_mod – Shallow Water","text":"Lax-Wendroff (second-order in space and time) scheme for the SWE. Uses a predictor-corrector (two-step Richtmyer) formulation:\n  Step 1 (predictor): compute half-step values at cell interfaces.\n  Step 2 (corrector): update full-step cell averages using interface fluxes. Uses shallow_water_mod constants_mod Subroutines public  subroutine lax_wendroff_step (state, b, dx, dy, dt) Advance the SWE state by one time step using the Lax-Wendroff scheme.\nCurrently implemented for 1-D (y-averaged) flow as a placeholder;\nthe full 2-D extension is left for a future implementation. Arguments Type Intent Optional Attributes Name type( SWEState ), intent(inout) :: state real(kind=dp), intent(in) :: b (:,:) real(kind=dp), intent(in) :: dx real(kind=dp), intent(in) :: dy real(kind=dp), intent(in) :: dt","tags":"","url":"module\\lax_wendroff_mod.html"},{"title":"grid_mod – Shallow Water","text":"Abstract grid interface.  Concrete implementations (Cartesian, …) extend\nthis module. Uses constants_mod Derived Types type, public :: GridBase Minimal grid descriptor shared by all grid types. Components Type Visibility Attributes Name Initial integer, public :: nx integer, public :: ny real(kind=dp), public :: dx real(kind=dp), public :: dy","tags":"","url":"module\\grid_mod.html"},{"title":"cartesian_grid_mod – Shallow Water","text":"Regular Cartesian (rectangular) grid with uniform spacing. Uses grid_mod parameters_mod constants_mod Derived Types type, public, extends( GridBase ) :: CartesianGrid Cartesian grid type. Components Type Visibility Attributes Name Initial integer, public :: nx integer, public :: ny real(kind=dp), public :: dx real(kind=dp), public :: dy real(kind=dp), public, allocatable :: x (:) 1-D arrays of cell-centre coordinates real(kind=dp), public, allocatable :: y (:) Subroutines public  subroutine build_cartesian_grid (grid, params) Allocate and populate a CartesianGrid from the simulation parameters. Arguments Type Intent Optional Attributes Name type( CartesianGrid ), intent(out) :: grid type( SimParams ), intent(in) :: params public  subroutine destroy_cartesian_grid (grid) Deallocate arrays inside a CartesianGrid. Arguments Type Intent Optional Attributes Name type( CartesianGrid ), intent(inout) :: grid","tags":"","url":"module\\cartesian_grid_mod.html"},{"title":"input_mod – Shallow Water","text":"Routines for reading simulation configuration from a namelist file. Expected namelist file format (FORTRAN NAMELIST): &sim_params\n    nx = 200,\n    ny = 200,\n    x_max = 500.0,\n    t_end = 200.0,\n  / Uses parameters_mod constants_mod Subroutines public  subroutine read_namelist (params, filename) Read simulation parameters from a NAMELIST file.\nFalls back to default_params() values for any unset keys. Arguments Type Intent Optional Attributes Name type( SimParams ), intent(out) :: params character(len=*), intent(in) :: filename","tags":"","url":"module\\input_mod.html"},{"title":"terrain_mod – Shallow Water","text":"Bathymetry / terrain module. The bottom topography b(x,y) enters the SWE source term.\nThis module defines the data structure and provides procedures to\ninitialise b on a CartesianGrid for a selection of analytic shapes\n(flat bottom, Gaussian hill, step, …). Uses cartesian_grid_mod constants_mod Variables Type Visibility Attributes Name Initial integer, public, parameter :: TERRAIN_FLAT = 0 Supported terrain presets integer, public, parameter :: TERRAIN_GAUSSIAN_HILL = 1 integer, public, parameter :: TERRAIN_STEP = 2 Subroutines public  subroutine init_terrain_flat (b, grid) Flat bottom: b = 0 everywhere. Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: b (:,:) type( CartesianGrid ), intent(in) :: grid public  subroutine init_terrain_gaussian_hill (b, grid, amplitude, sigma) Gaussian hill centred in the domain.\nb(x,y) = amplitude * exp( -((x-x0)&#94;2 + (y-y0)&#94;2) / (2*sigma&#94;2) ) Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: b (:,:) type( CartesianGrid ), intent(in) :: grid real(kind=dp), intent(in) :: amplitude real(kind=dp), intent(in) :: sigma public  subroutine init_terrain_step (b, grid, x_step, height) Step bathymetry: b = 0 for x < x_step, b = height for x >= x_step. Arguments Type Intent Optional Attributes Name real(kind=dp), intent(out) :: b (:,:) type( CartesianGrid ), intent(in) :: grid real(kind=dp), intent(in) :: x_step real(kind=dp), intent(in) :: height","tags":"","url":"module\\terrain_mod.html"},{"title":"main – Shallow Water","text":"Uses parameters_mod input_mod output_mod constants_mod terrain_mod cartesian_grid_mod shallow_water_mod euler_mod Entry point for the shallow water equations solver. Usage:\n  ./shallow_water [config.nml] If no config file is given, default parameters are used. Variables Type Attributes Name Initial type( SimParams ) :: params type( CartesianGrid ) :: grid type( SWEState ) :: state real(kind=dp), allocatable :: b (:,:) character(len=256) :: config_file integer :: step real(kind=dp) :: t logical :: do_output","tags":"","url":"program\\main.html"},{"title":"  sim_params – Shallow Water\n","text":"Variables Name Type Default Description nx integer None ny integer None x_min real(kind=dp) None x_max real(kind=dp) None y_min real(kind=dp) None y_max real(kind=dp) None t_start real(kind=dp) None t_end real(kind=dp) None dt real(kind=dp) None cfl real(kind=dp) None output_freq integer None output_dir character(len=256) None","tags":"","url":"namelist\\sim_params.html"},{"title":"parameters_mod.f90 – Shallow Water","text":"Source Code !> @file parameters_mod.f90 !> Runtime simulation parameters (read from config or set as defaults). module parameters_mod use constants_mod , only : dp implicit none private !> Simulation parameters type bundling all run-time settings. type , public :: SimParams !> Grid dimensions integer :: nx = 100 !< Number of cells in x-direction integer :: ny = 100 !< Number of cells in y-direction !> Domain extents (metres) real ( dp ) :: x_min = 0.0_dp real ( dp ) :: x_max = 100 0.0_dp real ( dp ) :: y_min = 0.0_dp real ( dp ) :: y_max = 100 0.0_dp !> Temporal settings real ( dp ) :: t_start = 0.0_dp !< Start time (s) real ( dp ) :: t_end = 10 0.0_dp !< End time (s) real ( dp ) :: dt = 0.1_dp !< Time step (s) real ( dp ) :: cfl = 0.5_dp !< CFL number for adaptive time-stepping !> Output settings integer :: output_freq = 10 !< Write output every N steps character ( len = 256 ) :: output_dir = 'output' end type SimParams public :: default_params contains !> Return a SimParams struct filled with default values. function default_params () result ( p ) type ( SimParams ) :: p p % nx = 100 p % ny = 100 p % x_min = 0.0_dp p % x_max = 100 0.0_dp p % y_min = 0.0_dp p % y_max = 100 0.0_dp p % t_start = 0.0_dp p % t_end = 10 0.0_dp p % dt = 0.1_dp p % cfl = 0.5_dp p % output_freq = 10 p % output_dir = 'output' end function default_params end module parameters_mod","tags":"","url":"sourcefile\\parameters_mod.f90.html"},{"title":"output_mod.f90 – Shallow Water","text":"Source Code !> @file output_mod.f90 !> Routines for writing simulation results to disk. !> !> Supported formats: !>   - Plain text CSV (one file per time step) – easy to read from Python/React !>   - Simple binary (raw doubles) for performance – TODO module output_mod use constants_mod , only : dp use shallow_water_mod , only : SWEState implicit none private public :: write_csv contains !> Write the current state to a CSV file. !> !> File path: <output_dir>/<prefix>_<step>.csv !> Columns: x_index, y_index, h, u, v, hu, hv subroutine write_csv ( state , x , y , step , output_dir , prefix ) type ( SWEState ), intent ( in ) :: state real ( dp ), intent ( in ) :: x (:), y (:) integer , intent ( in ) :: step character ( len =* ), intent ( in ) :: output_dir character ( len =* ), intent ( in ) :: prefix character ( len = 512 ) :: filepath integer :: unit , i , j , nx , ny , ios real ( dp ) :: u_ij , v_ij nx = size ( state % h , 1 ) ny = size ( state % h , 2 ) write ( filepath , '(A,A,A,A,I0,A)' ) & trim ( output_dir ), '/' , trim ( prefix ), '_' , step , '.csv' open ( newunit = unit , file = trim ( filepath ), status = 'replace' , & action = 'write' , iostat = ios ) if ( ios /= 0 ) then write ( * , '(A,A)' ) '[output] Error: cannot open file ' , trim ( filepath ) return end if write ( unit , '(A)' ) 'x,y,h,u,v,hu,hv' do j = 1 , ny do i = 1 , nx u_ij = merge ( state % hu ( i , j ) / state % h ( i , j ), 0.0_dp , state % h ( i , j ) > 0.0_dp ) v_ij = merge ( state % hv ( i , j ) / state % h ( i , j ), 0.0_dp , state % h ( i , j ) > 0.0_dp ) write ( unit , '(ES15.7,6(\",\",ES15.7))' ) & x ( i ), y ( j ), state % h ( i , j ), u_ij , v_ij , state % hu ( i , j ), state % hv ( i , j ) end do end do close ( unit ) end subroutine write_csv end module output_mod","tags":"","url":"sourcefile\\output_mod.f90.html"},{"title":"flux_mod.f90 – Shallow Water","text":"Source Code !> @file flux_mod.f90 !> Numerical flux computations for the SWE. !> !> Provides Riemann-solver-based flux routines to be used by the !> higher-level time-integration schemes.  Currently implements: !>   - Local Lax-Friedrichs (Rusanov) flux module flux_mod use constants_mod , only : dp , GRAVITY use shallow_water_mod , only : SWEState implicit none private public :: rusanov_flux_x public :: rusanov_flux_y public :: max_wave_speed contains !> Compute the maximum wave speed across the domain. !> Used for CFL-limited time-step selection. function max_wave_speed ( state ) result ( smax ) type ( SWEState ), intent ( in ) :: state real ( dp ) :: smax real ( dp ) :: c , u , v integer :: i , j , nx , ny nx = size ( state % h , 1 ) ny = size ( state % h , 2 ) smax = 0.0_dp do j = 1 , ny do i = 1 , nx if ( state % h ( i , j ) > 0.0_dp ) then c = sqrt ( GRAVITY * state % h ( i , j )) u = state % hu ( i , j ) / state % h ( i , j ) v = state % hv ( i , j ) / state % h ( i , j ) smax = max ( smax , abs ( u ) + c , abs ( v ) + c ) end if end do end do end function max_wave_speed !> Rusanov (local Lax-Friedrichs) flux in the x-direction at the !> interface between cell (i,j) and (i+1,j). subroutine rusanov_flux_x ( fh , fhu , fhv , state , i , j ) real ( dp ), intent ( out ) :: fh , fhu , fhv type ( SWEState ), intent ( in ) :: state integer , intent ( in ) :: i , j real ( dp ) :: hL , huL , hvL , uL , cL real ( dp ) :: hR , huR , hvR , uR , cR real ( dp ) :: smax hL = state % h ( i , j ); huL = state % hu ( i , j ); hvL = state % hv ( i , j ) hR = state % h ( i + 1 , j ); huR = state % hu ( i + 1 , j ); hvR = state % hv ( i + 1 , j ) uL = merge ( huL / hL , 0.0_dp , hL > 0.0_dp ) uR = merge ( huR / hR , 0.0_dp , hR > 0.0_dp ) cL = sqrt ( GRAVITY * max ( hL , 0.0_dp )) cR = sqrt ( GRAVITY * max ( hR , 0.0_dp )) smax = max ( abs ( uL ) + cL , abs ( uR ) + cR ) fh = 0.5_dp * ( huL + huR ) - 0.5_dp * smax * ( hR - hL ) fhu = 0.5_dp * ( huL * uL + 0.5_dp * GRAVITY * hL ** 2 & + huR * uR + 0.5_dp * GRAVITY * hR ** 2 ) & - 0.5_dp * smax * ( huR - huL ) fhv = 0.5_dp * ( hvL * uL + hvR * uR ) - 0.5_dp * smax * ( hvR - hvL ) end subroutine rusanov_flux_x !> Rusanov flux in the y-direction at the interface (i,j)-(i,j+1). subroutine rusanov_flux_y ( fh , fhu , fhv , state , i , j ) real ( dp ), intent ( out ) :: fh , fhu , fhv type ( SWEState ), intent ( in ) :: state integer , intent ( in ) :: i , j real ( dp ) :: hB , huB , hvB , vB , cB real ( dp ) :: hT , huT , hvT , vT , cT real ( dp ) :: smax hB = state % h ( i , j ); huB = state % hu ( i , j ); hvB = state % hv ( i , j ) hT = state % h ( i , j + 1 ); huT = state % hu ( i , j + 1 ); hvT = state % hv ( i , j + 1 ) vB = merge ( hvB / hB , 0.0_dp , hB > 0.0_dp ) vT = merge ( hvT / hT , 0.0_dp , hT > 0.0_dp ) cB = sqrt ( GRAVITY * max ( hB , 0.0_dp )) cT = sqrt ( GRAVITY * max ( hT , 0.0_dp )) smax = max ( abs ( vB ) + cB , abs ( vT ) + cT ) fh = 0.5_dp * ( hvB + hvT ) - 0.5_dp * smax * ( hT - hB ) fhu = 0.5_dp * ( huB * vB + huT * vT ) - 0.5_dp * smax * ( huT - huB ) fhv = 0.5_dp * ( hvB * vB + 0.5_dp * GRAVITY * hB ** 2 & + hvT * vT + 0.5_dp * GRAVITY * hT ** 2 ) & - 0.5_dp * smax * ( hvT - hvB ) end subroutine rusanov_flux_y end module flux_mod","tags":"","url":"sourcefile\\flux_mod.f90.html"},{"title":"time_integration_mod.f90 – Shallow Water","text":"Source Code !> @file time_integration_mod.f90 !> Abstract interface for time-integration schemes. !> !> All concrete integrators (Euler, Runge-Kutta, Lax-Wendroff, …) must !> expose a subroutine with the signature defined by the abstract interface !> `advance_step` below. module time_integration_mod use constants_mod , only : dp use shallow_water_mod , only : SWEState implicit none private !> Abstract interface satisfied by every time-integration scheme. abstract interface subroutine advance_step ( state , b , dx , dy , dt ) import :: dp , SWEState type ( SWEState ), intent ( inout ) :: state !< In: current, Out: updated real ( dp ), intent ( in ) :: b (:,:) !< Bed elevation real ( dp ), intent ( in ) :: dx , dy !< Spatial step sizes real ( dp ), intent ( in ) :: dt !< Time step end subroutine advance_step end interface !> Procedure pointer type matching the abstract interface. public :: advance_step public :: IntegratorPtr type , public :: IntegratorPtr procedure ( advance_step ), pointer , nopass :: ptr => null () end type IntegratorPtr end module time_integration_mod","tags":"","url":"sourcefile\\time_integration_mod.f90.html"},{"title":"shallow_water_mod.f90 – Shallow Water","text":"Source Code !> @file shallow_water_mod.f90 !> Core module defining the SWE state vector and the right-hand-side (RHS) !> of the 2-D shallow water equations. !> !> The 2-D SWE in conservation form are: !> !>   ∂h/∂t   + ∂(hu)/∂x + ∂(hv)/∂y  = 0 !>   ∂(hu)/∂t + ∂(hu²+g h²/2)/∂x + ∂(huv)/∂y = -g h ∂b/∂x !>   ∂(hv)/∂t + ∂(huv)/∂x + ∂(hv²+g h²/2)/∂y = -g h ∂b/∂y !> !> where h = water depth, u = x-velocity, v = y-velocity, b = bed elevation, !> g = gravitational acceleration. module shallow_water_mod use constants_mod , only : dp , GRAVITY implicit none private !> SWE state on a 2-D grid. type , public :: SWEState real ( dp ), allocatable :: h (:,:) !< Water depth         (m) real ( dp ), allocatable :: hu (:,:) !< x-momentum (h*u)    (m²/s) real ( dp ), allocatable :: hv (:,:) !< y-momentum (h*v)    (m²/s) end type SWEState public :: allocate_state public :: deallocate_state public :: compute_rhs contains !> Allocate state arrays for an nx × ny grid. subroutine allocate_state ( state , nx , ny ) type ( SWEState ), intent ( out ) :: state integer , intent ( in ) :: nx , ny allocate ( state % h ( nx , ny )) allocate ( state % hu ( nx , ny )) allocate ( state % hv ( nx , ny )) state % h = 0.0_dp state % hu = 0.0_dp state % hv = 0.0_dp end subroutine allocate_state !> Deallocate state arrays. subroutine deallocate_state ( state ) type ( SWEState ), intent ( inout ) :: state if ( allocated ( state % h )) deallocate ( state % h ) if ( allocated ( state % hu )) deallocate ( state % hu ) if ( allocated ( state % hv )) deallocate ( state % hv ) end subroutine deallocate_state !> Compute the RHS of the SWE using simple central differences. !> This is a placeholder; production code should use a proper !> Riemann-solver-based flux (see flux_mod.f90). subroutine compute_rhs ( rhs , state , b , dx , dy ) type ( SWEState ), intent ( out ) :: rhs !< Tendencies d/dt(h, hu, hv) type ( SWEState ), intent ( in ) :: state !< Current state real ( dp ), intent ( in ) :: b (:,:) !< Bed elevation (m) real ( dp ), intent ( in ) :: dx , dy !< Grid spacing  (m) integer :: nx , ny , i , j real ( dp ) :: dFhx , dFhvy , dGhux , dGhvy real ( dp ) :: dFhux , dGhuy real ( dp ) :: src_u , src_v , h_ij nx = size ( state % h , 1 ) ny = size ( state % h , 2 ) call allocate_state ( rhs , nx , ny ) do j = 2 , ny - 1 do i = 2 , nx - 1 h_ij = state % h ( i , j ) ! Mass equation: ∂h/∂t = -∂(hu)/∂x - ∂(hv)/∂y dFhx = ( state % hu ( i + 1 , j ) - state % hu ( i - 1 , j )) / ( 2.0_dp * dx ) dFhvy = ( state % hv ( i , j + 1 ) - state % hv ( i , j - 1 )) / ( 2.0_dp * dy ) rhs % h ( i , j ) = - dFhx - dFhvy ! x-momentum: ∂(hu)/∂t = -∂F_x/∂x - ∂(huv)/∂y + src_x dFhux = ( state % hu ( i + 1 , j ) ** 2 / max ( state % h ( i + 1 , j ), 1.0e-6_dp ) & + 0.5_dp * GRAVITY * state % h ( i + 1 , j ) ** 2 & - state % hu ( i - 1 , j ) ** 2 / max ( state % h ( i - 1 , j ), 1.0e-6_dp ) & - 0.5_dp * GRAVITY * state % h ( i - 1 , j ) ** 2 ) / ( 2.0_dp * dx ) dGhuy = ( state % hu ( i , j + 1 ) * state % hv ( i , j + 1 ) / max ( state % h ( i , j + 1 ), 1.0e-6_dp ) & - state % hu ( i , j - 1 ) * state % hv ( i , j - 1 ) / max ( state % h ( i , j - 1 ), 1.0e-6_dp )) & / ( 2.0_dp * dy ) src_u = - GRAVITY * h_ij * ( b ( i + 1 , j ) - b ( i - 1 , j )) / ( 2.0_dp * dx ) rhs % hu ( i , j ) = - dFhux - dGhuy + src_u ! y-momentum: ∂(hv)/∂t = -∂(huv)/∂x - ∂G_y/∂y + src_y dGhux = ( state % hu ( i + 1 , j ) * state % hv ( i + 1 , j ) / max ( state % h ( i + 1 , j ), 1.0e-6_dp ) & - state % hu ( i - 1 , j ) * state % hv ( i - 1 , j ) / max ( state % h ( i - 1 , j ), 1.0e-6_dp )) & / ( 2.0_dp * dx ) dGhvy = ( state % hv ( i , j + 1 ) ** 2 / max ( state % h ( i , j + 1 ), 1.0e-6_dp ) & + 0.5_dp * GRAVITY * state % h ( i , j + 1 ) ** 2 & - state % hv ( i , j - 1 ) ** 2 / max ( state % h ( i , j - 1 ), 1.0e-6_dp ) & - 0.5_dp * GRAVITY * state % h ( i , j - 1 ) ** 2 ) / ( 2.0_dp * dy ) src_v = - GRAVITY * h_ij * ( b ( i , j + 1 ) - b ( i , j - 1 )) / ( 2.0_dp * dy ) rhs % hv ( i , j ) = - dGhux - dGhvy + src_v end do end do end subroutine compute_rhs end module shallow_water_mod","tags":"","url":"sourcefile\\shallow_water_mod.f90.html"},{"title":"runge_kutta_mod.f90 – Shallow Water","text":"Source Code !> @file runge_kutta_mod.f90 !> Classical 4th-order Runge-Kutta (RK4) time integration for the SWE. module runge_kutta_mod use constants_mod , only : dp use shallow_water_mod , only : SWEState , compute_rhs , & allocate_state , deallocate_state implicit none private public :: rk4_step contains !> Advance the SWE state by one time step using the classical RK4 method. subroutine rk4_step ( state , b , dx , dy , dt ) type ( SWEState ), intent ( inout ) :: state real ( dp ), intent ( in ) :: b (:,:) real ( dp ), intent ( in ) :: dx , dy , dt type ( SWEState ) :: k1 , k2 , k3 , k4 , tmp integer :: nx , ny nx = size ( state % h , 1 ) ny = size ( state % h , 2 ) call allocate_state ( tmp , nx , ny ) ! k1 = RHS(U&#94;n) call compute_rhs ( k1 , state , b , dx , dy ) ! k2 = RHS(U&#94;n + dt/2 * k1) tmp % h = state % h + 0.5_dp * dt * k1 % h tmp % hu = state % hu + 0.5_dp * dt * k1 % hu tmp % hv = state % hv + 0.5_dp * dt * k1 % hv call compute_rhs ( k2 , tmp , b , dx , dy ) ! k3 = RHS(U&#94;n + dt/2 * k2) tmp % h = state % h + 0.5_dp * dt * k2 % h tmp % hu = state % hu + 0.5_dp * dt * k2 % hu tmp % hv = state % hv + 0.5_dp * dt * k2 % hv call compute_rhs ( k3 , tmp , b , dx , dy ) ! k4 = RHS(U&#94;n + dt * k3) tmp % h = state % h + dt * k3 % h tmp % hu = state % hu + dt * k3 % hu tmp % hv = state % hv + dt * k3 % hv call compute_rhs ( k4 , tmp , b , dx , dy ) ! U&#94;{n+1} = U&#94;n + dt/6 * (k1 + 2*k2 + 2*k3 + k4) state % h = state % h + ( dt / 6.0_dp ) * ( k1 % h + 2.0_dp * k2 % h + 2.0_dp * k3 % h + k4 % h ) state % hu = state % hu + ( dt / 6.0_dp ) * ( k1 % hu + 2.0_dp * k2 % hu + 2.0_dp * k3 % hu + k4 % hu ) state % hv = state % hv + ( dt / 6.0_dp ) * ( k1 % hv + 2.0_dp * k2 % hv + 2.0_dp * k3 % hv + k4 % hv ) call deallocate_state ( k1 ) call deallocate_state ( k2 ) call deallocate_state ( k3 ) call deallocate_state ( k4 ) call deallocate_state ( tmp ) end subroutine rk4_step end module runge_kutta_mod","tags":"","url":"sourcefile\\runge_kutta_mod.f90.html"},{"title":"euler_mod.f90 – Shallow Water","text":"Source Code !> @file euler_mod.f90 !> Forward Euler (first-order explicit) time integration for the SWE. module euler_mod use constants_mod , only : dp use shallow_water_mod , only : SWEState , compute_rhs , & allocate_state , deallocate_state implicit none private public :: euler_step contains !> Advance the SWE state by one time step using the forward Euler method. !> !>   U&#94;{n+1} = U&#94;n + dt * RHS(U&#94;n) subroutine euler_step ( state , b , dx , dy , dt ) type ( SWEState ), intent ( inout ) :: state real ( dp ), intent ( in ) :: b (:,:) real ( dp ), intent ( in ) :: dx , dy , dt type ( SWEState ) :: rhs call compute_rhs ( rhs , state , b , dx , dy ) state % h = state % h + dt * rhs % h state % hu = state % hu + dt * rhs % hu state % hv = state % hv + dt * rhs % hv call deallocate_state ( rhs ) end subroutine euler_step end module euler_mod","tags":"","url":"sourcefile\\euler_mod.f90.html"},{"title":"main.f90 – Shallow Water","text":"Source Code !> @file main.f90 !> Entry point for the shallow water equations solver. !> !> Usage: !>   ./shallow_water [config.nml] !> !> If no config file is given, default parameters are used. program main use constants_mod , only : dp use parameters_mod , only : SimParams , default_params use input_mod , only : read_namelist use cartesian_grid_mod , only : CartesianGrid , build_cartesian_grid , & destroy_cartesian_grid use terrain_mod , only : init_terrain_flat use shallow_water_mod , only : SWEState , allocate_state , deallocate_state use euler_mod , only : euler_step use output_mod , only : write_csv implicit none type ( SimParams ) :: params type ( CartesianGrid ) :: grid type ( SWEState ) :: state real ( dp ), allocatable :: b (:,:) ! bed elevation character ( len = 256 ) :: config_file integer :: step real ( dp ) :: t logical :: do_output ! ---- Parse command-line argument ---------------------------------------- if ( command_argument_count () >= 1 ) then call get_command_argument ( 1 , config_file ) call read_namelist ( params , trim ( config_file )) else params = default_params () write ( * , '(A)' ) '[main] No config file given – using defaults.' end if ! ---- Build grid ---------------------------------------------------------- call build_cartesian_grid ( grid , params ) ! ---- Allocate state and terrain ----------------------------------------- call allocate_state ( state , params % nx , params % ny ) allocate ( b ( params % nx , params % ny )) ! Default terrain: flat bottom call init_terrain_flat ( b , grid ) ! Default initial condition: still water of uniform depth = 1 m state % h = 1.0_dp state % hu = 0.0_dp state % hv = 0.0_dp write ( * , '(A,I0,A,I0,A)' ) '[main] Grid: ' , params % nx , ' x ' , params % ny , ' cells' write ( * , '(A,F8.1,A,F8.1,A)' ) '[main] Time: ' , params % t_start , ' -> ' , params % t_end , ' s' ! ---- Time loop ---------------------------------------------------------- t = params % t_start step = 0 do while ( t < params % t_end ) ! Clamp last step if ( t + params % dt > params % t_end ) params % dt = params % t_end - t call euler_step ( state , b , grid % dx , grid % dy , params % dt ) t = t + params % dt step = step + 1 do_output = ( mod ( step , params % output_freq ) == 0 ) if ( do_output ) then call write_csv ( state , grid % x , grid % y , step , & trim ( params % output_dir ), 'swe' ) write ( * , '(A,I6,A,F10.3)' ) '[main] step ' , step , '  t = ' , t end if end do write ( * , '(A)' ) '[main] Simulation complete.' ! ---- Clean up ----------------------------------------------------------- call deallocate_state ( state ) call destroy_cartesian_grid ( grid ) deallocate ( b ) end program main","tags":"","url":"sourcefile\\main.f90.html"},{"title":"constants_mod.f90 – Shallow Water","text":"Source Code !> @file constants_mod.f90 !> Physical and mathematical constants used throughout the solver. module constants_mod implicit none private !> Double-precision kind parameter integer , parameter , public :: dp = kind ( 1.0d0 ) !> Pi real ( dp ), parameter , public :: PI = 3.14159265358979323846_dp !> Gravitational acceleration (m/s&#94;2) real ( dp ), parameter , public :: GRAVITY = 9.81_dp !> A small tolerance for floating-point comparisons real ( dp ), parameter , public :: EPS = 1.0e-10_dp end module constants_mod","tags":"","url":"sourcefile\\constants_mod.f90.html"},{"title":"lax_wendroff_mod.f90 – Shallow Water","text":"Source Code !> @file lax_wendroff_mod.f90 !> Lax-Wendroff (second-order in space and time) scheme for the SWE. !> !> Uses a predictor-corrector (two-step Richtmyer) formulation: !>   Step 1 (predictor): compute half-step values at cell interfaces. !>   Step 2 (corrector): update full-step cell averages using interface fluxes. module lax_wendroff_mod use constants_mod , only : dp , GRAVITY use shallow_water_mod , only : SWEState , allocate_state , deallocate_state implicit none private public :: lax_wendroff_step contains !> Advance the SWE state by one time step using the Lax-Wendroff scheme. !> Currently implemented for 1-D (y-averaged) flow as a placeholder; !> the full 2-D extension is left for a future implementation. subroutine lax_wendroff_step ( state , b , dx , dy , dt ) type ( SWEState ), intent ( inout ) :: state real ( dp ), intent ( in ) :: b (:,:) real ( dp ), intent ( in ) :: dx , dy , dt integer :: nx , ny nx = size ( state % h , 1 ) ny = size ( state % h , 2 ) ! TODO: implement full 2-D Lax-Wendroff / Richtmyer two-step scheme. ! Placeholder: fall through without modifying state. write ( * , '(A)' ) '[lax_wendroff] WARNING: full 2-D scheme not yet implemented.' end subroutine lax_wendroff_step end module lax_wendroff_mod","tags":"","url":"sourcefile\\lax_wendroff_mod.f90.html"},{"title":"grid_mod.f90 – Shallow Water","text":"Source Code !> @file grid_mod.f90 !> Abstract grid interface.  Concrete implementations (Cartesian, …) extend !> this module. module grid_mod use constants_mod , only : dp implicit none private !> Minimal grid descriptor shared by all grid types. type , public :: GridBase integer :: nx !< Number of interior cells in x integer :: ny !< Number of interior cells in y real ( dp ) :: dx !< Cell width  (m) real ( dp ) :: dy !< Cell height (m) end type GridBase end module grid_mod","tags":"","url":"sourcefile\\grid_mod.f90.html"},{"title":"cartesian_grid_mod.f90 – Shallow Water","text":"Source Code !> @file cartesian_grid_mod.f90 !> Regular Cartesian (rectangular) grid with uniform spacing. module cartesian_grid_mod use constants_mod , only : dp use grid_mod , only : GridBase use parameters_mod , only : SimParams implicit none private !> Cartesian grid type. type , extends ( GridBase ), public :: CartesianGrid !> 1-D arrays of cell-centre coordinates real ( dp ), allocatable :: x (:) !< x cell-centre positions (m) real ( dp ), allocatable :: y (:) !< y cell-centre positions (m) end type CartesianGrid public :: build_cartesian_grid public :: destroy_cartesian_grid contains !> Allocate and populate a CartesianGrid from the simulation parameters. subroutine build_cartesian_grid ( grid , params ) type ( CartesianGrid ), intent ( out ) :: grid type ( SimParams ), intent ( in ) :: params integer :: i , j grid % nx = params % nx grid % ny = params % ny grid % dx = ( params % x_max - params % x_min ) / real ( params % nx , dp ) grid % dy = ( params % y_max - params % y_min ) / real ( params % ny , dp ) allocate ( grid % x ( params % nx )) allocate ( grid % y ( params % ny )) do i = 1 , params % nx grid % x ( i ) = params % x_min + ( real ( i , dp ) - 0.5_dp ) * grid % dx end do do j = 1 , params % ny grid % y ( j ) = params % y_min + ( real ( j , dp ) - 0.5_dp ) * grid % dy end do end subroutine build_cartesian_grid !> Deallocate arrays inside a CartesianGrid. subroutine destroy_cartesian_grid ( grid ) type ( CartesianGrid ), intent ( inout ) :: grid if ( allocated ( grid % x )) deallocate ( grid % x ) if ( allocated ( grid % y )) deallocate ( grid % y ) end subroutine destroy_cartesian_grid end module cartesian_grid_mod","tags":"","url":"sourcefile\\cartesian_grid_mod.f90.html"},{"title":"input_mod.f90 – Shallow Water","text":"Source Code !> @file input_mod.f90 !> Routines for reading simulation configuration from a namelist file. !> !> Expected namelist file format (FORTRAN NAMELIST): !> !>   &sim_params !>     nx = 200, !>     ny = 200, !>     x_max = 500.0, !>     t_end = 200.0, !>   / module input_mod use constants_mod , only : dp use parameters_mod , only : SimParams , default_params implicit none private public :: read_namelist contains !> Read simulation parameters from a NAMELIST file. !> Falls back to default_params() values for any unset keys. subroutine read_namelist ( params , filename ) type ( SimParams ), intent ( out ) :: params character ( len =* ), intent ( in ) :: filename integer :: nx , ny , output_freq , unit , ios real ( dp ) :: x_min , x_max , y_min , y_max real ( dp ) :: t_start , t_end , dt , cfl character ( len = 256 ) :: output_dir namelist / sim_params / nx , ny , x_min , x_max , y_min , y_max , & t_start , t_end , dt , cfl , & output_freq , output_dir ! Start from defaults params = default_params () ! Mirror defaults into local variables so unset keys keep defaults nx = params % nx ny = params % ny x_min = params % x_min x_max = params % x_max y_min = params % y_min y_max = params % y_max t_start = params % t_start t_end = params % t_end dt = params % dt cfl = params % cfl output_freq = params % output_freq output_dir = params % output_dir open ( newunit = unit , file = trim ( filename ), status = 'old' , action = 'read' , iostat = ios ) if ( ios /= 0 ) then write ( * , '(A,A)' ) '[input] Warning: cannot open namelist file: ' , trim ( filename ) write ( * , '(A)' ) '[input] Using default parameters.' return end if read ( unit , nml = sim_params , iostat = ios ) close ( unit ) if ( ios /= 0 ) then write ( * , '(A,A)' ) '[input] Warning: error reading namelist: ' , trim ( filename ) end if params % nx = nx params % ny = ny params % x_min = x_min params % x_max = x_max params % y_min = y_min params % y_max = y_max params % t_start = t_start params % t_end = t_end params % dt = dt params % cfl = cfl params % output_freq = output_freq params % output_dir = output_dir end subroutine read_namelist end module input_mod","tags":"","url":"sourcefile\\input_mod.f90.html"},{"title":"terrain_mod.f90 – Shallow Water","text":"Source Code !> @file terrain_mod.f90 !> Bathymetry / terrain module. !> !> The bottom topography b(x,y) enters the SWE source term. !> This module defines the data structure and provides procedures to !> initialise b on a CartesianGrid for a selection of analytic shapes !> (flat bottom, Gaussian hill, step, …). module terrain_mod use constants_mod , only : dp , PI use cartesian_grid_mod , only : CartesianGrid implicit none private !> Supported terrain presets integer , parameter , public :: TERRAIN_FLAT = 0 integer , parameter , public :: TERRAIN_GAUSSIAN_HILL = 1 integer , parameter , public :: TERRAIN_STEP = 2 public :: init_terrain_flat public :: init_terrain_gaussian_hill public :: init_terrain_step contains !> Flat bottom: b = 0 everywhere. subroutine init_terrain_flat ( b , grid ) real ( dp ), intent ( out ) :: b (:,:) type ( CartesianGrid ), intent ( in ) :: grid b = 0.0_dp end subroutine init_terrain_flat !> Gaussian hill centred in the domain. !> b(x,y) = amplitude * exp( -((x-x0)&#94;2 + (y-y0)&#94;2) / (2*sigma&#94;2) ) subroutine init_terrain_gaussian_hill ( b , grid , amplitude , sigma ) real ( dp ), intent ( out ) :: b (:,:) type ( CartesianGrid ), intent ( in ) :: grid real ( dp ), intent ( in ) :: amplitude !< Peak height (m) real ( dp ), intent ( in ) :: sigma !< Spread parameter (m) integer :: i , j real ( dp ) :: x0 , y0 , r2 x0 = grid % x ( grid % nx / 2 ) y0 = grid % y ( grid % ny / 2 ) do j = 1 , grid % ny do i = 1 , grid % nx r2 = ( grid % x ( i ) - x0 ) ** 2 + ( grid % y ( j ) - y0 ) ** 2 b ( i , j ) = amplitude * exp ( - r2 / ( 2.0_dp * sigma ** 2 )) end do end do end subroutine init_terrain_gaussian_hill !> Step bathymetry: b = 0 for x < x_step, b = height for x >= x_step. subroutine init_terrain_step ( b , grid , x_step , height ) real ( dp ), intent ( out ) :: b (:,:) type ( CartesianGrid ), intent ( in ) :: grid real ( dp ), intent ( in ) :: x_step !< Step position (m) real ( dp ), intent ( in ) :: height !< Step height  (m) integer :: i , j do j = 1 , grid % ny do i = 1 , grid % nx if ( grid % x ( i ) >= x_step ) then b ( i , j ) = height else b ( i , j ) = 0.0_dp end if end do end do end subroutine init_terrain_step end module terrain_mod","tags":"","url":"sourcefile\\terrain_mod.f90.html"}]}